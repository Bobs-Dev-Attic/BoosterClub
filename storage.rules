rules_version = '2';

// Cloud Storage upload rules. Three folders are in use:
//   /minutes  - meeting-minutes PDFs (public read; Contributor+ write, <=20 MB)
//   /funding  - photos attached to funding requests (signed-in read/write, <=10 MB)
//   /gallery  - shared media library images (public read; gallery managers write)
// Everything else in the bucket is implicitly denied (no matching rule).
service firebase.storage {
  match /b/{bucket}/o {
    function role() {
      return request.auth != null
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : 'guest';
    }

    match /minutes/{file} {
      allow read: if true;
      allow write: if role() in ['contributor', 'administrator', 'webAdmin']
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    // Photos attached to funding requests. Funding requests are not public
    // (see firestore.rules), so their photos aren't either: reads require
    // sign-in. Any signed-in member may upload an image up to 10 MB.
    match /funding/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Shared media library. Published images are publicly readable (the public
    // Gallery page shows them to guests). UPLOADS are restricted to gallery
    // managers by base role — the same roles that hold manage_gallery by
    // default and that the Gallery admin UI is shown to — so a random signed-in
    // user can't drop a public-URL image into the bucket. (Managers who hold
    // manage_gallery only via a delegated grant should upload from an account
    // whose base role is Contributor or above; Storage rules can't see
    // delegated grants.)
    match /gallery/{file} {
      allow read: if true;
      allow write: if role() in ['contributor', 'administrator', 'webAdmin']
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
