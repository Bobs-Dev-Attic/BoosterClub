rules_version = '2';

// Cloud Storage upload rules. Three folders are in use:
//   /minutes  - meeting-minutes PDFs (public read; Contributor+ write, <=20 MB)
//   /funding  - photos attached to funding requests (any signed-in user, <=10 MB)
//   /gallery  - shared media library images (any signed-in user, <=10 MB)
// Everything else in the bucket is implicitly denied (no matching rule).
service firebase.storage {
  match /b/{bucket}/o {
    function role() {
      return request.auth != null
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : 'guest';
    }

    match /minutes/{file} {
      allow read: if true;
      allow write: if role() in ['contributor', 'administrator', 'webAdmin']
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    // Photos attached to funding requests: any signed-in member may upload an
    // image up to 10 MB.
    match /funding/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Shared media library: publicly readable. Any signed-in user may upload an
    // image up to 10 MB (same as funding photos). Who can actually *publish* a
    // gallery entry is gated separately by the Firestore `gallery` collection
    // rule (manage_gallery) — an uploaded file that isn't referenced by a
    // gallery document is never surfaced in the app. This avoids a cross-service
    // role() lookup that was denying legitimate Contributor uploads.
    match /gallery/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
